# Copy values from this file into local .env after creating/selecting your GCP project.
# Do not commit real project-specific secrets or credentials.

GCP_PROJECT_ID=replace-me-project
GCP_REGION=asia-south1
GCP_BILLING_ACCOUNT_ID=
BUDGET_ALERT_AMOUNT_USD=25
ALLOW_TERRAFORM_APPLY_CORE=

ARTIFACT_REGISTRY_REPOSITORY=smartcity
IMAGE_REGISTRY=asia-south1-docker.pkg.dev/replace-me-project/smartcity
IMAGE_TAG=local

GCP_PUBSUB_TOPIC=smartcity-readings
GCP_PUBSUB_DLQ_TOPIC=smartcity-dlq
GCP_PUBSUB_SUBSCRIPTION=smartcity-hot-writer
INGESTION_SINK=local
PUBSUB_MAX_MESSAGES=100
PUBSUB_CONSUME_LIMIT=10
PUBSUB_CONSUME_TIMEOUT_SECONDS=60
GCS_BUCKET=smartcity-zero-disk-iot-pa-cold
BIGQUERY_DATASET=smartcity_iot
BIGQUERY_EXTERNAL_TABLE=sensor_readings_external
COLD_STORAGE_TARGET=local
CLOUD_COLD_EXPORT_KEEP_LOCAL=true
CLOUD_COLD_MIN_ROWS=0
BIGQUERY_COLD_CHECK_ATTEMPTS=6
BIGQUERY_COLD_CHECK_SLEEP_SECONDS=10
GKE_CLUSTER_NAME=smartcity-autopilot
GKE_NAMESPACE=smartcity
ALLOW_TERRAFORM_APPLY_RUNTIME=
RUNTIME_IMAGE_TAG=slice17
K8S_TIMESCALE_DB=smartcity_hot
K8S_TIMESCALE_USER=smartcity
K8S_TIMESCALE_PASSWORD=
K8S_TIMESCALE_STORAGE_SIZE=10Gi
K8S_TIMESCALE_IMAGE=timescale/timescaledb:latest-pg15
