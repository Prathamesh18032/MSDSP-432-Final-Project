# Local environment template for the Smart City Zero-Disk IoT project.
# Copy this file to .env and fill in real values as needed.

APP_ENV=local
LOG_LEVEL=info

# Local TimescaleDB hot layer
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5432
TIMESCALE_DB=smartcity_hot
TIMESCALE_USER=smartcity
TIMESCALE_PASSWORD=smartcity_dev_password
TIMESCALE_DSN=postgres://smartcity:smartcity_dev_password@localhost:5432/smartcity_hot?sslmode=disable

# Local PostgreSQL metadata store
METADATA_DB_HOST=localhost
METADATA_DB_PORT=5433
METADATA_DB_NAME=smartcity_metadata
METADATA_DB_USER=smartcity_meta
METADATA_DB_PASSWORD=smartcity_meta_dev_password

# Ingestion settings
OPENAQ_BASE_URL=https://api.openaq.org
OPENAQ_POLL_INTERVAL_SECONDS=60
SIMULATOR_READINGS_PER_SECOND=10
BACKPRESSURE_CHANNEL_CAPACITY=10000
BACKPRESSURE_DROP_THRESHOLD_PCT=80

# Cloud-ready settings. Leave blank for local-first development.
GCP_PROJECT_ID=
GCP_REGION=us-central1
GCP_PUBSUB_TOPIC=smartcity-readings
GCP_PUBSUB_DLQ_TOPIC=smartcity-dlq
GCS_BUCKET=smartcity-iot
BIGQUERY_DATASET=smartcity_iot

# Dashboard ports
GRAFANA_PORT=3000
STREAMLIT_PORT=8501
