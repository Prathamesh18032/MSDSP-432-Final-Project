# Local environment template for the Smart City Zero-Disk IoT project.
# Copy this file to .env and fill in real values as needed.

APP_ENV=local
LOG_LEVEL=info

# Local TimescaleDB hot layer
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5432
TIMESCALE_DB=smartcity_hot
TIMESCALE_USER=smartcity
TIMESCALE_PASSWORD=smartcity_dev_password
TIMESCALE_DSN=postgres://smartcity:smartcity_dev_password@localhost:5432/smartcity_hot?sslmode=disable

# Local PostgreSQL metadata store
METADATA_DB_HOST=localhost
METADATA_DB_PORT=5433
METADATA_DB_NAME=smartcity_metadata
METADATA_DB_USER=smartcity_meta
METADATA_DB_PASSWORD=smartcity_meta_dev_password

# Ingestion settings
INGESTION_SINK=local
OPENAQ_BASE_URL=https://api.openaq.org
OPENAQ_API_KEY=
OPENAQ_COORDINATES=41.8781,-87.6298
OPENAQ_RADIUS_METERS=25000
OPENAQ_LOCATION_LIMIT=5
OPENAQ_POLL_INTERVAL_SECONDS=60
MULTISOURCE_POLL_INTERVAL_SECONDS=300
OPENMETEO_BASE_URL=https://api.open-meteo.com
OPENMETEO_COORDINATES=41.8781,-87.6298
GBFS_DISCOVERY_URL=https://gbfs.divvybikes.com/gbfs/gbfs.json
GBFS_LANGUAGE=en
GBFS_STATION_LIMIT=25
USGS_BASE_URL=https://waterservices.usgs.gov
USGS_SITE_IDS=05536123
USGS_PARAMETER_CODES=00065
SIMULATOR_READINGS_PER_SECOND=10
BACKPRESSURE_CHANNEL_CAPACITY=10000
BACKPRESSURE_DROP_THRESHOLD_PCT=80
QUEUE_BATCH_SIZE=100
QUEUE_FLUSH_INTERVAL_MS=1000

# Optional video AI agent settings
VIDEO_AGENT_INPUT_DIR=data/video_inbox
VIDEO_AGENT_CITY=chicago
VIDEO_AGENT_CAMERA_ID=demo-001
VIDEO_AGENT_THRESHOLD=0.65
VIDEO_AGENT_MODEL=OPear/videomae-large-finetuned-UCF-Crime
VIDEO_AGENT_BINARY_MODEL=dima806/crime_cctv_image_detection
VIDEO_AGENT_TYPE_MODEL=dima806/crime_type_cctv_image_detection
VIDEO_AGENT_CRIME_THRESHOLD=0.50
VIDEO_AGENT_MODEL_VERSION=mvp
VIDEO_AGENT_MOCK_MODEL=true
VIDEO_AGENT_DRY_RUN=false
VIDEO_AGENT_POLL_SECONDS=10800
VIDEO_AGENT_DATASET_MAX_MB=200
VIDEO_AGENT_DATASET_MAX_NORMAL=70
VIDEO_AGENT_DATASET_MAX_ANOMALY=15
VIDEO_AGENT_DATASET_SOURCE_DIR=
VIDEO_AGENT_KAGGLE_DATASET=odins0n/ucf-crime-dataset
VIDEO_AGENT_DATASET_CLASSES=Assault,Robbery,RoadAccidents,Fighting,Burglary,Stealing,Shoplifting,Normal Videos
VIDEO_AGENT_SOURCE_VIDEO=
VIDEO_AGENT_GCS_PREFIX=video_inbox
VIDEO_AGENT_PUBSUB_TOPIC=smartcity-video-events
VIDEO_AGENT_PUBSUB_SUBSCRIPTION=smartcity-video-agent
VIDEO_AGENT_REPLICAS=0

# Local cold storage export settings
COLD_STORAGE_ROOT=data/cold
COLD_STORAGE_TARGET=local
COLD_EXPORT_HOT_RETENTION_HOURS=72
COLD_EXPORT_BATCH_SIZE=1000
COLD_EXPORT_MODE=retention
CLOUD_COLD_EXPORT_KEEP_LOCAL=true

# Cloud-ready settings. Leave blank for local-first development.
GCP_PROJECT_ID=
GCP_REGION=asia-south1
GCP_PUBSUB_TOPIC=smartcity-readings
GCP_PUBSUB_DLQ_TOPIC=smartcity-dlq
GCP_PUBSUB_SUBSCRIPTION=smartcity-hot-writer
PUBSUB_MAX_MESSAGES=100
GCS_BUCKET=smartcity-zero-disk-iot-pa-cold
BIGQUERY_DATASET=smartcity_iot
BIGQUERY_EXTERNAL_TABLE=sensor_readings_external
CLOUD_COLD_MIN_ROWS=0
BIGQUERY_COLD_CHECK_ATTEMPTS=6
BIGQUERY_COLD_CHECK_SLEEP_SECONDS=10
ARTIFACT_REGISTRY_REPOSITORY=smartcity
GKE_CLUSTER_NAME=smartcity-autopilot
GKE_NAMESPACE=smartcity
IMAGE_REGISTRY=asia-south1-docker.pkg.dev/replace-me-project/smartcity
IMAGE_TAG=local
RUNTIME_IMAGE_TAG=latest-main
RUNTIME_EXPECTED_IMAGE_TAG=latest-main
RUNTIME_IDLE_SCALE_TIMESCALE=false
RUNTIME_COST_ACK=false
RUNTIME_EVIDENCE_DIR=artifacts/evidence
GITHUB_ACTIONS_IMAGE_TAG=short-sha
GCP_WORKLOAD_IDENTITY_PROVIDER=
GCP_CI_SERVICE_ACCOUNT=
RESTORE_TEST_NAMESPACE=smartcity-restore-test
RESTORE_TEST_STORAGE_SIZE=5Gi
RESTORE_TEST_BACKUP_URI=latest
BUDGET_ALERT_AMOUNT_USD=
GCP_BILLING_ACCOUNT_ID=
ALLOW_TERRAFORM_APPLY_CORE=
ALLOW_TERRAFORM_APPLY_RUNTIME=
ALLOW_PUBLIC_INGRESS=
PUBLIC_DEMO_ENABLED=false
PUBLIC_DEMO_DOMAIN=
PUBLIC_DEMO_STATIC_IP_NAME=smartcity-demo-ip
STREAMLIT_DEMO_PASSWORD=
PUBLIC_DEMO_DELETE_STATIC_IP=

# GKE self-hosted TimescaleDB runtime settings
K8S_TIMESCALE_DB=smartcity_hot
K8S_TIMESCALE_USER=smartcity
K8S_TIMESCALE_PASSWORD=
K8S_TIMESCALE_STORAGE_SIZE=10Gi
K8S_TIMESCALE_IMAGE=timescale/timescaledb:latest-pg15
TIMESCALE_BACKUP_SCHEDULE="0 */6 * * *"
TIMESCALE_BACKUP_RETENTION_DAYS=14
TIMESCALE_BACKUP_PREFIX=backups/timescaledb
TIMESCALE_BACKUP_TIMEOUT_SECONDS=600
TIMESCALE_BACKUP_LOCAL_ROOT=/tmp/smartcity-backups

# Dashboard ports
GRAFANA_PORT=3000
STREAMLIT_PORT=8501
STREAMLIT_TIMESCALE_DSN=postgresql://smartcity:smartcity_dev_password@localhost:5432/smartcity_hot
STREAMLIT_COLD_STORAGE_ROOT=data/cold
STREAMLIT_REFRESH_SECONDS=60
STREAMLIT_DEFAULT_WINDOW_HOURS=24
STREAMLIT_BRAND_TITLE=Smart City Command Center
STREAMLIT_CITY_NAME=Chicago
STREAMLIT_ENABLE_GBFS_STATION_NAMES=true

# Pub/Sub smoke settings
PUBSUB_CONSUME_LIMIT=10
PUBSUB_CONSUME_TIMEOUT_SECONDS=60
